# Godot 4+ specific ignores
# https://github.com/godotengine/godot/blob/master/.gitignore

# Editor-generated cache, imports, and shader cache
.godot/
*.translation

# Imported assets re-import on first open
*.import

# Android template (regenerated by Godot)
/android/

# iOS / macOS export builds
/ios/
*.xcodeproj/
*.xcarchive/

# Web export
/web/

# Mono / C# (if using GDScript only, these never appear)
.mono/
.import/
mono_crash.*.json
data_*/
[Bb]in/
[Oo]bj/
*.csproj.user
*.sln.DotSettings.user

# Godot exports — never commit built binaries
/build/
/builds/
/export/
/exports/
/dist/
*.pck
*.zip
*.exe
*.x86_64
*.x86_32
*.app
*.apk
*.aab
*.ipa
*.dmg
*.wasm

# OS-specific
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code (per-user local settings)
.claude/settings.local.json

# Logs
*.log
logs/
